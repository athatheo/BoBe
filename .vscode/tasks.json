{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "just build",
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "test",
      "type": "shell",
      "command": "just test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "clippy",
      "type": "shell",
      "command": "cargo clippy --all-targets",
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "serve",
      "type": "shell",
      "command": "just serve",
      "group": "none",
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
