{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "lib": ["ESNext"]
  },
  "include": ["electron/**/*", "electron-vite.config.ts", "src/types/**/*", "src/lib/constants.ts"]
}
