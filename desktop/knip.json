{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "electron/main/index.ts",
    "electron/preload/index.ts",
    "src/app/index.tsx",
    "src/settings-app/index.tsx",
    "src/features/setup/index.tsx",
    "src/types/window.d.ts",
    "e2e/**/*.spec.ts",
    "e2e/fixtures/*.ts",
    "build/*.js",
    "scripts/*.ts"
  ],
  "project": ["electron/**/*.ts", "src/**/*.{ts,tsx}", "e2e/**/*.ts"],
  "ignoreBinaries": [
    "only-allow",
    "license-checker",
    "GPL-3.0",
    "AGPL-1.0",
    "AGPL-3.0",
    "SSPL-1.0"
  ],
  "ignoreDependencies": [
    "electron-playwright-helpers",
    "tailwindcss",
    "@tailwindcss/vite",
    "@vitejs/plugin-react"
  ],
  "ignoreExportsUsedInFile": true
}
